<?xml version="1.0"?>
<!--
=============================================================================
CLICKHOUSE — МИНИМАЛЬНЫЙ КОНФИГ
=============================================================================
Только самое необходимое:
1. Ротация логов (чтобы не заполнить диск)
2. Таймзона
3. Сетевые настройки для Docker
=============================================================================
-->
<clickhouse>
    <!-- 
    =========================================================================
    ЛОГИРОВАНИЕ (ОБЯЗАТЕЛЬНО!)
    =========================================================================
    Без этих настроек логи будут расти бесконечно
    -->
    <logger>
        <level>information</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <!-- Ротация: максимум 100MB на файл -->
        <size>100M</size>
        <!-- Хранить максимум 5 файлов (итого ~500MB) -->
        <count>5</count>
        <!-- Сжимать старые логи -->
        <compress>true</compress>
    </logger>

    <!-- 
    =========================================================================
    ТАЙМЗОНА
    =========================================================================
    Важно для правильной работы с датами GA4
    -->
    <timezone>Asia/Bishkek</timezone>

    <!-- 
    =========================================================================
    СЕТЬ
    =========================================================================
    Слушать на всех интерфейсах (нужно для Docker)
    -->
    <listen_host>0.0.0.0</listen_host>
</clickhouse>
