# ============================================================================
# DataStack v2 — Airflow 3.1.7 (CeleryExecutor)
# ============================================================================
# Скопируйте в .env и заполните реальные значения.
# .env в .gitignore — НИКОГДА не коммитить!
# ============================================================================

AIRFLOW_UID=50000

# ── PostgreSQL (Airflow Metadata DB) ──
POSTGRES_USER=airflow
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=airflow

# ══════════════════════════════════════════════════════════════
# AIRFLOW CONFIGURATION
# Формат: AIRFLOW__SECTION__KEY → airflow.cfg [section] key
# ══════════════════════════════════════════════════════════════

# ── [core] ──
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=YOUR_FERNET_KEY
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__DEFAULT_TIMEZONE=Asia/Bishkek
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=4
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=8
AIRFLOW__CORE__EXECUTION_API_SERVER_URL=http://airflow-api-server:8080/execution/
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_USERS=admin:admin

# ── [database] ──
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:YOUR_PASSWORD@airflow-postgres:5432/airflow

# ── [celery] ──
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:YOUR_PASSWORD@airflow-postgres:5432/airflow

# ── [api] ──
AIRFLOW__API__SECRET_KEY=YOUR_SECRET_KEY
AIRFLOW__API__WORKERS=2
AIRFLOW__API_AUTH__JWT_SECRET=YOUR_JWT_SECRET

# ── [scheduler / dag_processor / logging] ──
AIRFLOW__DAG_PROCESSOR__REFRESH_INTERVAL=60
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=30
AIRFLOW__SCHEDULER__PARSING_PROCESSES=2
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__LOGGING__DAG_PROCESSOR_LOG_TARGET=stdout

# ══════════════════════════════════════════════════════════════
# ВНЕШНИЕ СЕРВИСЫ (используются dbt и Python-утилитами)
# ══════════════════════════════════════════════════════════════

# ── ClickHouse (единый набор — для dbt и Python-утилит) ──
CLICKHOUSE_HOST=datastack2-clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=YOUR_CLICKHOUSE_PASSWORD

# ── MinIO (S3-совместимое хранилище) ──
MINIO_ENDPOINT=datastack2-minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=YOUR_MINIO_SECRET
MINIO_BUCKET_RAW=raw-data

# ── GCP (BigQuery доступ) ──
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/credentials/gcp-service-account.json

# ── Telegram Monitoring ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8218949365:AAHPRkKBgcqFUpaG1TqplL1D0st8S3uFP1s
TELEGRAM_CHAT_ID=-1003860680282

# Topic IDs (для справки — используются через константы в telegram_client.py)
# TOPIC_ALERTS=1340
# TOPIC_DAILY=1343
# TOPIC_PIPELINE=1347
# TOPIC_HEALTH=1350

# ── PostgreSQL микросервисы ────────────────────
PG_MICRO_HOST=185.138.184.198
PG_MICRO_PORT=5432
PG_MICRO_USER=dauser
PG_MICRO_PASSWORD=YOUR_PASSWORD
PG_MICRO_SSLCERT=/opt/airflow/credentials/pg_server.crt

# MySQL 5.7 (старый монолит)
MYSQL_HOST=85.195.124.74
MYSQL_PORT=3306
MYSQL_USER=product_user
MYSQL_PASSWORD=YOUR_PASSWORD
MYSQL_DATABASE=tachka
